{
  "name": "react-seo-head",
  "version": "1.0.0",
  "description": "Lightweight, dependency-free React library for managing <head> elements declaratively",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "license": "MIT",

  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },

  "files": [
    "dist"
  ],

  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },

  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0"
  },

  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  }
}
